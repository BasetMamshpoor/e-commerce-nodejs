{
  "info": {
    "name": "e-commerce",
    "_postman_id": "f4d3d8b5-a5d1-4f93-b0f5-123456789abc",
    "description": "Authentication APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000/api/v1"
    },
    {
      "key": "identifier",
      "value": "[test@example.com](mailto:test@example.com)"
    },
    {
      "key": "password",
      "value": "Password123"
    },
    {
      "key": "otp",
      "value": "123456"
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "accessToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  'fullName': 'Test User',\n  'identifier': '{{identifier}}',\n  'password': '{{password}}'\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        }
      }
    },
    {
      "name": "Verify Register OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  'identifier': '{{identifier}}',\n  'code': '{{otp}}',\n  'deviceName': 'Windows Chrome'\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register/verify-otp",
          "path": ["auth", "register", "verify-otp"]
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  'identifier': '{{identifier}}',\n  'password': '{{password}}',\n  'deviceName': 'Windows Chrome'\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "Request Login OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  'identifier': '{{identifier}}'\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login/otp/request",
          "path": ["auth", "login", "otp", "request"]
        }
      }
    },
    {
      "name": "Verify Login OTP",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  'identifier': '{{identifier}}',\n  'code': '{{otp}}',\n  'deviceName': 'Windows Chrome'\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login/otp/verify",
          "path": ["auth", "login", "otp", "verify"]
        }
      }
    },
    {
      "name": "Refresh Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  'refreshToken': '{{refreshToken}}'\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/refresh-token",
          "path": ["auth", "refresh-token"]
        }
      }
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/logout",
          "path": ["auth", "logout"]
        }
      }
    },
    {
      "name": "Logout All Devices",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/logout-all",
          "path": ["auth", "logout-all"]
        }
      }
    },
    {
      "name": "Forgot Password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  'identifier': '{{identifier}}'\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/forgot-password",
          "path": ["auth", "forgot-password"]
        }
      }
    },
    {
      "name": "Reset Password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  'identifier': '{{identifier}}',\n  'code': '{{otp}}',\n  'newPassword': 'NewPassword123'\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/reset-password",
          "path": ["auth", "reset-password"]
        }
      }
    }
  ]
}
